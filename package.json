{
  "name": "trackpilot",
  "version": "0.8.1",
  "description": "AI-friendly command-line copilot for driving YouTrack Cloud against a git repo: read specs, create and update issues, and generate release diffs for QA.",
  "type": "module",
  "bin": "bin/trackpilot.mjs",
  "exports": {
    ".": {
      "types": "./src/api.d.ts",
      "import": "./src/api.mjs"
    }
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "trackpilot": "node bin/trackpilot.mjs",
    "test": "node --test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/keyring": "^1.3.0",
    "zod": "^4.4.3"
  },
  "keywords": [
    "youtrack",
    "cli",
    "issues",
    "ai",
    "agent",
    "release",
    "qa",
    "git"
  ],
  "license": "MIT",
  "author": "javadtavakoli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/javadtavakoli/trackpilot.git"
  },
  "bugs": {
    "url": "https://github.com/javadtavakoli/trackpilot/issues"
  },
  "homepage": "https://www.fullhouse.click/trackpilot",
  "packageManager": "yarn@4.14.1",
  "devDependencies": {
    "conventional-changelog-cli": "^5.0.0",
    "conventional-recommended-bump": "^11.2.0",
    "semver": "^7.8.1"
  }
}
